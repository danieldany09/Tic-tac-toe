# ─── Copy this file to .env and fill in real values ───────────────────────────
# NEVER commit .env to version control.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_NAME=nakama
DB_USER=nakama_user
DB_PASSWORD=CHANGE_ME_strong_db_password

# ── Nakama ─────────────────────────────────────────────────────────────────────
# HTTP key – used to call server-to-server / HTTP runtime functions
NAKAMA_HTTP_KEY=CHANGE_ME_http_key

# Console admin credentials (access via SSH tunnel only in production)
NAKAMA_CONSOLE_USERNAME=admin
NAKAMA_CONSOLE_PASSWORD=CHANGE_ME_console_password

# ── Domain (production only) ───────────────────────────────────────────────────
# Your server's public IP or domain name (used in deployment docs / Nginx config)
DOMAIN=your-server-ip-or-domain.com
